{
  "name": "forgemark-vscode",
  "displayName": "ForgeMark",
  "publisher": "forgemark",
  "description": "ForgeMark UI スケルトンのライブプレビュー",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "engines": {
    "vscode": "^1.80.0",
    "node": ">=20.0.0"
  },
  "categories": ["Other"],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "forgemark.openPreview",
        "title": "プレビューを開く",
        "category": "ForgeMark"
      }
    ]
  },
  "scripts": {
    "build": "npm run build:ext && npm run build:webview",
    "build:ext": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --platform=node --format=cjs --sourcemap",
    "build:webview": "vite build --config vite.webview.config.ts",
    "watch:ext": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --platform=node --format=cjs --sourcemap --watch",
    "watch:webview": "vite build --config vite.webview.config.ts --watch"
  },
  "dependencies": {
    "@forgemark/core": "*"
  },
  "devDependencies": {
    "@forgemark/renderer": "*",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/vscode": "^1.80.0",
    "@vitejs/plugin-react": "^4.3.4",
    "esbuild": "^0.24.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.4.0",
    "vite": "^6.0.0"
  }
}
